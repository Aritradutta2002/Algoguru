# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"
SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# ── Payment / Support credentials ────────────────────────────────────────────
VITE_UPI_ID="yourname@bankhandle"
VITE_RAZORPAY_URL="https://rzp.io/l/your_payment_link"
VITE_PAYPAL_URL="https://paypal.me/YourName"
VITE_BUYMEACOFFEE_URL="https://buymeacoffee.com/YourName"
VITE_CRYPTO_ADDRESS=""        # leave empty to hide the Crypto tab
